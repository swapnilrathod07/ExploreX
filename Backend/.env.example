# ================================================
# EXPLOREX BACKEND - ENVIRONMENT CONFIGURATION
# ================================================
# Copy this file to .env and update values
# DO NOT commit .env to git (only .env.example)

# SERVER CONFIGURATION
# Render sets PORT automatically. Keep 5000 only for local development.
PORT=5000
NODE_ENV=production

# DATABASE CONFIGURATION
# Railway production example: mysql://root:PASSWORD@reseau.proxy.rlwy.net:13962/railway
DATABASE_URL=
DB_HOST=your_mysql_host
DB_PORT=3306
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_NAME=your_mysql_database
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000

# JWT & AUTHENTICATION
# Generate random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PHONE_OTP_TTL_MINUTES=10
EMAIL_OTP_TTL_MINUTES=10
PHONE_OTP_RESEND_COOLDOWN_SECONDS=25
EMAIL_OTP_RESEND_COOLDOWN_SECONDS=25

# PASSWORD RESET / EMAIL OTP DELIVERY
# console/dev = prints reset codes/OTP in backend terminal
# smtp        = sends real email via SMTP (Gmail SMTP supported)
# none        = generates reset code only, no delivery
EMAIL_PROVIDER=console
APP_NAME=ExploreX
SUPPORT_EMAIL=support@explorex.com
FRONTEND_APP_URL=https://YOUR_GITHUB_USERNAME.github.io/YOUR_REPOSITORY_NAME
EMAIL_FROM="ExploreX Support <no-reply@explorex.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Gmail SMTP example:
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=yourgmail@gmail.com
# SMTP_PASS=your_16_character_google_app_password
# EMAIL_FROM="ExploreX <yourgmail@gmail.com>"

# PHONE OTP SMS DELIVERY
# dev     = local development; OTP prints in backend terminal, not on frontend
# console = prints OTP in backend terminal
# msg91   = sends OTP by MSG91
# twilio  = sends OTP by Twilio Programmable SMS
# custom  = sends OTP to your own webhook
SMS_OTP_PROVIDER=dev
SMS_OTP_MESSAGE=Your ExploreX verification code is {{OTP}}. It expires in {{MINUTES}} minutes. Do not share it.

# MSG91 OTP CONFIG (recommended for India)
# Create an OTP template in MSG91, then paste auth key + template id here.
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=

# TWILIO SMS CONFIG (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# CUSTOM SMS WEBHOOK CONFIG (optional)
SMS_OTP_WEBHOOK_URL=
SMS_OTP_WEBHOOK_TOKEN=

# CORS SECURITY (NO wildcards in production!)
# Production example for GitHub Pages. Add local origins only in local .env, not Render.
FRONTEND_ORIGIN=https://blissful-quietude-production-752f.up.railway.app

# ADMIN CONFIGURATION
ADMIN_EMAILS=admin@explorex.in
SUPER_ADMIN_EMAILS=admin@explorex.in
ADMIN_PIN_EXPIRES_IN=2h

# EXTERNAL SERVICES (Optional)
# Free road routing priority: OpenRouteService key (optional) -> OSRM public providers -> Valhalla -> local estimate.
# Create a free key at openrouteservice.org and paste it in Backend/.env as OPENROUTESERVICE_API_KEY=your_key
OPENROUTESERVICE_API_KEY=
ROUTE_ORS_URL=https://api.openrouteservice.org
ROUTE_OSRM_URLS=https://router.project-osrm.org,https://routing.openstreetmap.de/routed-car
# Keep route UI fast. Increase only if your network/provider is reliable but slow.
ROUTE_TIMEOUT_MS=4500
ROUTE_FETCH_RETRIES=1
ROUTE_VALHALLA_URL=https://valhalla1.openstreetmap.de
GEOCODE_COUNTRYCODES=in
UPLOAD_IMAGE_MAX_BYTES=6291456

# DEBUGGING & LOGGING
DEBUG=false
EXPOSE_RESET_TOKEN_IN_RESPONSE=false
EXPOSE_PASSWORD_RESET_CODE_IN_RESPONSE=false
EXPOSE_OTP_IN_RESPONSE=false

# SCHEDULED JOBS
PUBLISH_DUE_JOB_ENABLED=true
PUBLISH_DUE_JOB_INTERVAL_SECONDS=60
PUBLISH_DUE_JOB_RUN_ON_START=true
